# ======================================================================
# Firebase — client SDK (PUBLIC, exposé au navigateur)
# ======================================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Domaines email autorisés (séparés par des virgules)
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=chanv.com,bleuh.co,lafeuilleverte.ca,maisondherbes.com

# URL du Hub (widgets chatbot, feedback, Gandalf sidebar)
NEXT_PUBLIC_HUB_URL=

# ======================================================================
# Gestion des accès — ID Firestore de l'app Coach Gandalf dans la
# collection `apps` du Hub Gandalf. Si défini, le code lit directement
# user_app_roles/{email}__{COACHGANDA_APP_ID} (zéro ambiguïté de nom).
# Sinon, fallback sur le matcher par nom.
# L'ID sera disponible après avoir ajouté l'app via l'interface du Hub.
# ======================================================================
COACHGANDA_APP_ID=

# ======================================================================
# Firebase Admin SDK — SERVEUR UNIQUEMENT
# JSON complet du service account sur une seule ligne (ou Secret Manager en prod)
# ======================================================================
FIREBASE_SERVICE_ACCOUNT_JSON=

# ======================================================================
# Clé API LLM pour la génération de programmes d'entraînement (serveur)
# ======================================================================
ANTHROPIC_API_KEY=

# ======================================================================
# Génération vidéo — Veo 3 via Google Gemini API (serveur)
# GEMINI_API_KEY : clé API Google AI Studio / Gemini.
# VEO_MODEL      : id du modèle Veo (optionnel, défaut: veo-3.1-generate-preview).
#                  Alternatives : veo-3.1-fast-generate-preview, veo-3.1-lite-generate-preview.
# ======================================================================
GEMINI_API_KEY=
VEO_MODEL=

# ======================================================================
# Cloud Storage — bucket des vidéos d'exercices (serveur).
# Optionnel : par défaut on réutilise NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET.
# ======================================================================
STORAGE_BUCKET=

# ======================================================================
# ExerciseDB (AscendAPI via RapidAPI) — import de vidéos de démonstration (serveur).
# Plan PAYANT requis pour l'usage commercial. EXERCISEDB_API_HOST optionnel
# (défaut: edb-with-videos-and-images-by-ascendapi.p.rapidapi.com).
# ======================================================================
EXERCISEDB_API_KEY=
EXERCISEDB_API_HOST=

# ======================================================================
# Spotify — lecture musicale pendant les séances (serveur).
# App à créer sur https://developer.spotify.com/dashboard.
# Redirect URI à déclarer : {APP_PUBLIC_URL}/api/spotify/callback
# Compte Spotify PREMIUM requis (Web Playback SDK).
# SPOTIFY_REDIRECT_URI : optionnel (défaut: APP_PUBLIC_URL + /api/spotify/callback).
# SPOTIFY_DEFAULT_PLAYLIST : optionnel (URI/ID/URL d'une playlist lancée par défaut).
# ======================================================================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=
SPOTIFY_DEFAULT_PLAYLIST=

# ======================================================================
# URL publique de l'app (utilisée dans les notifications, liens, etc.)
# ======================================================================
APP_PUBLIC_URL=
